---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Esteban Marín',
  description = 'Esteban Marín — Software Engineer (ex-Microsoft, Cosmos DB), Data Scientist with an MS from Universidad Complutense de Madrid, and ICPC World Finalist.',
} = Astro.props;

const ogImage = new URL('/og-image.png', Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/Logo.jpeg" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="site-nav" role="navigation" aria-label="Main navigation">
      <a class="nav-logo" href="/">EM</a>
      <div class="nav-links">
        <a href="/#experience">Experience</a>
        <a href="/#education">Education</a>
        <a href="/#projects">Projects</a>
        <a href="/#skills">Skills</a>
        <a href="/blog">Blog</a>
        <a
          href="/Eniram CV.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="nav-cv-btn"
          aria-label="View resume PDF (opens in new tab)">Resume</a
        >
      </div>
    </nav>

    <div class="page-content">
      <slot />
    </div>

    <footer>
      <div class="links">
        <a
          href="https://www.linkedin.com/in/esteban-marin-masis"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn Profile"
        >
          <svg
            class="footer-icon"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"
            ></path>
          </svg>
        </a>
        <a
          href="https://github.com/e-niram"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Github Profile"
        >
          <svg
            class="footer-icon"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"
            ></path>
          </svg>
        </a>
        <a
          href="mailto:eniram.contact@gmail.com"
          aria-label="Email Contact"
        >
          <svg
            class="footer-icon"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M22 4H2a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h20a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm-.4 4.25-8.53 6.09a1.5 1.5 0 0 1-1.74 0L2.4 8.25a.75.75 0 0 1 .87-1.22L12 12.5l8.73-5.47a.75.75 0 1 1 .87 1.22z"
            ></path>
          </svg>
        </a>
      </div>
    </footer>
  </body>
</html>
