---
const skillGroups = [
  {
    title: 'Frontend',
    skills: ['React', 'Next.js', 'Astro', 'Storybook', 'Figma'],
  },
  {
    title: 'Backend',
    skills: ['Django', 'Spring', 'Node.js', 'FastAPI'],
  },
  {
    title: 'Databases',
    skills: ['PostgreSQL', 'MongoDB', 'Redis', 'Supabase'],
  },
  {
    title: 'Programming Languages',
    skills: ['Python', 'C++', 'Java', 'TypeScript', 'SQL'],
  },
  {
    title: 'Data Science',
    skills: ['R', 'SAS', 'Machine Learning', 'Time Series'],
  },
  {
    title: 'DevOps',
    skills: ['Jenkins', 'Terraform', 'Docker', 'Kubernetes', 'Grafana', 'Datadog'],
  },
  {
    title: 'Cloud',
    subgroups: [
      { provider: 'AWS', skills: ['S3', 'EC2'] },
      { provider: 'Azure', skills: ['Cosmos DB'] },
      { provider: 'GCP', skills: ['Vertex AI'] },
    ],
  },
  {
    title: 'Natural Languages',
    skills: ['Spanish (Native)', 'English (C1)', 'French (B2)'],
  },
];
---

<!-- ── Skills ─────────────────────────────────────────── -->
<section class="skills" id="skills">
  <h2 class="section-heading">Skills</h2>
  <div class="skills-content">
    {
      skillGroups.map((group) => (
        <div class="skill-group">
          <h3>{group.title}</h3>
          {group.subgroups ? (
            <div class="skill-subgroups">
              {group.subgroups.map((subgroup) => (
                <div class="skill-subgroup">
                  <span class="skill-provider">{subgroup.provider}</span>
                  <div class="skill-tags">
                    {subgroup.skills.map((skill) => (
                      <span>{skill}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="skill-tags">
              {group.skills.map((skill) => (
                <span>{skill}</span>
              ))}
            </div>
          )}
        </div>
      ))
    }
  </div>
</section>
