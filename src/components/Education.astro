---
const degrees = [
  {
    level: 'Bachelor of Science',
    title: 'Computer Science',
    school: 'Universidad de Costa Rica',
    meta: '2018 – 2021',
    gpa: '9.50 / 10',
    note: 'Teaching Assistant for Programming I & II, Databases I, and Experimental Design.',
  },
  {
    level: 'Master of Science',
    title: 'Data Science',
    school: 'Universidad Complutense de Madrid',
    meta: '2025 – 2026',
    gpa: '9.18 / 10',
    note: 'Thesis: Monitoring noise pollution in Madrid using clustering and predictive models for time series.',
  },
];
---

<!-- ── Education ──────────────────────────────────────── -->
<section class="education" id="education">
  <h2 class="section-heading">Education</h2>
  <div class="education-content">
    {
      degrees.map((d) => (
        <div class="edu-card">
          <div class="edu-degree">
            <span class="edu-degree-level">{d.level}</span>
            <span class="edu-degree-title">{d.title}</span>
          </div>
          <div class="edu-school">
            <span>{d.school}</span>
          </div>
          <div class="edu-meta">
            <span class="edu-date">{d.meta}</span>
            {d.gpa && <span class="edu-gpa">GPA {d.gpa}</span>}
          </div>
          <div class="edu-note">{d.note}</div>
        </div>
      ))
    }
  </div>
</section>
