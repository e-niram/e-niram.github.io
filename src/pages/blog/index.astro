---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<BaseLayout
  title="Blog — Esteban Marín"
  description="Thoughts, learnings, and experiences on software engineering, data science, and more."
>
  <main class="blog-list-main">
    <header class="blog-list-header">
      <h1>Blog</h1>
      <p>Thoughts, learnings, and experiences.</p>
    </header>

    <div class="blog-grid">
      {
        posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="blog-card">
            <p class="blog-card-date">{post.data.pubDate}</p>
            <h2 class="blog-card-title">{post.data.title}</h2>
            <p class="blog-card-excerpt">{post.data.description}</p>
            <span class="blog-card-cta">Read post →</span>
          </a>
        ))
      }
    </div>
  </main>
</BaseLayout>

<style>
  .blog-list-main {
    max-width: 860px;
    margin: 0 auto;
    padding: 60px 20px 80px;
  }

  .blog-list-header {
    margin-bottom: 48px;
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 24px;
  }

  .blog-list-header h1 {
    font-size: 60px;
    font-weight: 800;
    color: var(--color-accent);
  }

  .blog-list-header p {
    font-size: 18px;
    color: var(--color-text);
    margin-top: 8px;
  }

  .blog-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .blog-card {
    display: block;
    background: #fff;
    border-radius: 12px;
    padding: 30px;
    border: 1.5px solid #e8e0d4;
    text-decoration: none;
    transition: transform 0.15s, border-color 0.15s;
  }

  .blog-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-accent);
  }

  .blog-card-date {
    font-size: 13px;
    color: var(--color-text);
    opacity: 0.65;
    margin-bottom: 8px;
  }

  .blog-card-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .blog-card-excerpt {
    font-size: 15px;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .blog-card-cta {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-accent);
  }
</style>
