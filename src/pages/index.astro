---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- ── Hero ───────────────────────────────────────────── -->
  <section class="home" id="home">
    <div class="container">
      <div class="column">
        <div class="content">
          <h1>Esteban Marín</h1>
        </div>
      </div>
      <div class="column">
        <div class="content">
          <h2>
            Software Engineer @ Microsoft
            <span class="hero-sub"
              >MS Data Science · ICPC World Finalist · Backend Systems</span
            >
          </h2>
          <p>
            Distributed systems engineer with a passion for data science,
            competitive programming, and teaching.
          </p>
          <a
            href="/Eniram CV.pdf"
            target="_blank"
            class="button"
            aria-label="View Esteban's resume (PDF, opens in new tab)"
            >View Resume</a
          >
          <button
            class="button-secondary"
            type="button"
            onclick="location.href='https://forms.gle/keMEehzVevNTucyX8'"
            aria-label="Contact Esteban"
          >
            Let's work
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Experience ─────────────────────────────────────── -->
  <section class="experience" id="experience">
    <h2 class="section-heading">Experience</h2>
    <div class="experience-content">

      <div class="row">
        <div class="card year">2025</div>
        <div class="card job">
          <h3 class="job-title">Big Tech</h3>
          <p class="job-description">
            Microsoft opened the door to Big Tech, where I work as a Software
            Engineer on{' '}
            <a
              aria-label="Azure Cosmos DB (opens in a new tab)"
              href="https://azure.microsoft.com/en-us/products/cosmos-db"
              target="_blank"
              class="cool-link">Cosmos DB</a
            > — Azure's globally distributed, multi-model database serving millions
            of requests daily. I contribute to the core engine of a system built
            for planetary-scale workloads and five-nines availability.
          </p>
        </div>
      </div>

      <div class="row">
        <div class="card double-year responsive-year-top">2023<br />2024</div>
        <div class="card job">
          <h3 class="job-title">Startup Hustle</h3>
          <p class="job-description">
            <a
              aria-label="Thoropass (opens in a new tab)"
              href="https://thoropass.com/"
              target="_blank"
              class="cool-link">Thoropass</a
            > — an end-to-end compliance automation platform — welcomed me to the
            startup world. My role was as dynamic as the environment: Frontend,
            Backend, Product Support, Scrum Master, Expositor. I shipped features
            used by enterprise customers undergoing SOC 2 and ISO 27001 audits, cutting
            compliance prep time from months to weeks. The memes were a bonus.
          </p>
        </div>
        <div class="card double-year responsive-year-bottom">2023<br />2024</div>
      </div>

      <div class="row">
        <div class="card year">2022</div>
        <div class="card job">
          <h3 class="job-title">E-commerce Newbie</h3>
          <p class="job-description">
            I kicked off my professional journey in the coolest way imaginable:
            snowboards, surfboards, and a whole lot of goats.{' '}
            <a
              aria-label="Backcountry (opens in a new tab)"
              href="https://www.backcountry.com/"
              target="_blank"
              class="cool-link">Backcountry</a
            > brought me on as an enthusiastic new grad. I built and maintained features
            across their e-commerce platform — serving millions of products and thousands
            of daily orders — while learning the craft of professional software engineering.
          </p>
        </div>
      </div>

      <div class="row">
        <div class="card year responsive-year-top">2021</div>
        <div class="card job">
          <h3 class="job-title">University Highlights</h3>
          <p class="job-description">
            My final year at{' '}
            <strong>Universidad de Costa Rica (BS, Computer Science)</strong>{' '}
            had it all: Teaching Assistant for three courses (Programming
            Fundamentals, Databases, and Experimental Design),{' '}
            <a
              aria-label="Angry Blocks Game (opens in a new tab)"
              href="https://creacion-videojuegos.github.io/ccf-build/"
              target="_blank"
              class="link">developed a game</a
            > in Unity, and wrapped up my coursework. As the cherry on top, I competed
            in the{' '}
            <a
              aria-label="ICPC World Finals (opens in a new tab)"
              href="https://worldfinals.icpc.global/index.html"
              target="_blank"
              class="cool-link">44<sup>th</sup> ICPC World Finals</a
            >, where my team was self-proclaimed{' '}
            <a
              aria-label="ICPC World Finals video (opens in a new tab)"
              href="https://www.youtube.com/watch?v=IcnLA1CHnL8&t=643s&ab_channel=ICPCNews"
              target="_blank"
              class="link">"Best Meet-the-Team Video"</a
            >.
          </p>
        </div>
        <div class="card year responsive-year-bottom">2021</div>
      </div>

    </div>
  </section>

  <!-- ── Education ──────────────────────────────────────── -->
  <section class="education" id="education">
    <h2 class="section-heading">Education</h2>
    <div class="education-content">

      <div class="edu-card">
        <div class="edu-degree">MS, Data Science</div>
        <div class="edu-school">Universidad de Costa Rica</div>
        <div class="edu-meta">2023 – Present</div>
        <div class="edu-note">
          Thesis: Acoustic noise spatial interpolation and unsupervised
          clustering using geostatistical methods.
        </div>
      </div>

      <div class="edu-card">
        <div class="edu-degree">BS, Computer Science</div>
        <div class="edu-school">Universidad de Costa Rica</div>
        <div class="edu-meta">2017 – 2022</div>
        <div class="edu-note">
          Teaching Assistant (3 courses). ICPC World Finalist, 44th edition.
        </div>
      </div>

    </div>
  </section>

  <!-- ── Projects & Research ────────────────────────────── -->
  <section class="projects" id="projects">
    <h2 class="section-heading">Projects & Research</h2>
    <div class="projects-grid">

      <div class="project-card">
        <div class="project-header">
          <h3>Acoustic Noise Interpolation & Clustering</h3>
          <span class="project-tag">Research · Thesis</span>
        </div>
        <p>
          Graduate thesis applying spatial interpolation and unsupervised
          clustering to acoustic noise data. Implemented in Python and R;
          written in LaTeX. Explores geostatistical methods to model urban
          noise distributions.
        </p>
      </div>

      <div class="project-card">
        <div class="project-header">
          <h3>Angry Blocks</h3>
          <span class="project-tag">Unity · C#</span>
        </div>
        <p>
          2D physics-based puzzle game built in Unity (C#) for a university
          game-development course.{' '}
          <a
            href="https://creacion-videojuegos.github.io/ccf-build/"
            target="_blank"
            class="cool-link">Play it here →</a
          >
        </p>
      </div>

      <div class="project-card">
        <div class="project-header">
          <h3>ICPC World Finals — 44th Edition</h3>
          <span class="project-tag">Competitive Programming</span>
        </div>
        <p>
          Competed against elite teams from top universities worldwide,
          solving complex algorithmic problems under time pressure.{' '}
          <a
            href="https://www.youtube.com/watch?v=IcnLA1CHnL8&t=643s"
            target="_blank"
            class="cool-link">Watch our meet-the-team video →</a
          >
        </p>
      </div>

    </div>
  </section>

  <!-- ── Skills ─────────────────────────────────────────── -->
  <section class="skills" id="skills">
    <h2 class="section-heading">Skills</h2>
    <div class="skills-content">

      <div class="skill-group">
        <h3>Languages</h3>
        <div class="skill-tags">
          <span>Python</span>
          <span>R</span>
          <span>SQL</span>
          <span>C#</span>
          <span>TypeScript</span>
          <span>SAS</span>
        </div>
      </div>

      <div class="skill-group">
        <h3>Cloud & Infrastructure</h3>
        <div class="skill-tags">
          <span>Azure Cosmos DB</span>
          <span>Azure Cloud</span>
          <span>Distributed Systems</span>
        </div>
      </div>

      <div class="skill-group">
        <h3>Data Science</h3>
        <div class="skill-tags">
          <span>Statistical Modeling</span>
          <span>Spatial Analysis</span>
          <span>Machine Learning</span>
          <span>LaTeX</span>
        </div>
      </div>

      <div class="skill-group">
        <h3>Other</h3>
        <div class="skill-tags">
          <span>Unity</span>
          <span>Competitive Programming</span>
          <span>Scrum / Agile</span>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
